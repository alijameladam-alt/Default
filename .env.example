# =============================================================================
# Viridis Media — Environment Variables
# Copy this file to `.env.local` and fill in real values. NEVER commit `.env.local`.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Supabase Postgres)
# -----------------------------------------------------------------------------
# Where to get these:
#   1. Go to https://supabase.com → create project (region: closest to your team).
#   2. In your project dashboard: Settings → Database → Connection string.
#   3. DATABASE_URL = "Transaction" pooler string (port 6543), used by the app at runtime.
#      MUST end with: ?pgbouncer=true&connection_limit=1
#   4. DIRECT_URL = "Direct connection" string (port 5432), used by Prisma migrations only.
DATABASE_URL="postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# -----------------------------------------------------------------------------
# Supabase API (for browser realtime subscription)
# -----------------------------------------------------------------------------
# Where to get these:
#   Supabase dashboard → Settings → API.
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-public-key>"
SUPABASE_SERVICE_ROLE_KEY="<service-role-secret-key>"   # SERVER-SIDE ONLY. Never expose to browser.

# -----------------------------------------------------------------------------
# NextAuth
# -----------------------------------------------------------------------------
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
NEXTAUTH_SECRET="<32-byte-base64-secret>"
NEXTAUTH_URL="http://localhost:3000"   # In production, set to your deployed URL.

# -----------------------------------------------------------------------------
# Google OAuth (for Sign-In + Calendar + Gmail)
# -----------------------------------------------------------------------------
# Where to get these:
#   1. https://console.cloud.google.com → create project (or pick existing).
#   2. APIs & Services → Library → enable: "Google Calendar API" and "Gmail API".
#   3. APIs & Services → OAuth consent screen → External, fill app info,
#      add scopes: openid, email, profile,
#                  https://www.googleapis.com/auth/calendar.events,
#                  https://www.googleapis.com/auth/gmail.readonly
#   4. APIs & Services → Credentials → Create OAuth client ID → Web application.
#      Authorized redirect URIs:
#        http://localhost:3000/api/auth/callback/google         (NextAuth sign-in)
#        http://localhost:3000/api/integrations/google/callback (Calendar/Gmail link)
#   5. Copy Client ID + Client Secret here.
GOOGLE_CLIENT_ID="<your-client-id>.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="<your-client-secret>"

# -----------------------------------------------------------------------------
# Encryption (for OAuth tokens at rest)
# -----------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
# Must be exactly 64 hex chars (32 bytes). AES-256-GCM key.
ENCRYPTION_KEY="<64-hex-char-key>"
